{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "paths": {
      "@nyaya/shared": [
        "../shared/src/index.ts"
      ],
      "@nyaya/shared/*": [
        "../shared/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "references": [
    {
      "path": "../shared"
    }
  ]
}
